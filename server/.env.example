# FastAPI server environment
ENVIRONMENT="development"
APP_NAME="AI Social Media Manager API"
API_HOST="0.0.0.0"
API_PORT="8000"
API_BASE_URL="http://localhost:8000"
FRONTEND_BASE_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# PostgreSQL / Prisma
# Replace this with your live PostgreSQL connection string before running Prisma commands.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Security
# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY="replace-with-a-valid-fernet-key"

# Google Cloud Storage
GCS_BUCKET_NAME="your-gcs-bucket-name"
GCS_PROJECT_ID="your-gcp-project-id"
GCS_SIGNED_URL_MINUTES="60"
GCS_MAKE_PUBLIC="false"
MAX_UPLOAD_BYTES="104857600"
MAX_REQUEST_BODY_BYTES="157286400"

# Google Application Credentials
# Option A: set this to the service account JSON file path on the server.
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/gcp-service-account.json"
# Option B: if your deploy platform supports secret files or workload identity,
# leave GOOGLE_APPLICATION_CREDENTIALS empty and configure credentials in the platform.

# AI / LLM agents
OPENAI_API_KEY="your-openai-api-key"
AI_COPYWRITER_MODEL="gpt-4.1-mini"
AI_REVIEWER_MODEL="gpt-4.1-mini"

# Image composition
IMAGE_OUTPUT_FORMAT="PNG"

# OAuth redirect URLs
OAUTH_REDIRECT_BASE_URL="http://localhost:8000"
OAUTH_SUCCESS_REDIRECT_URL="http://localhost:3000/settings/integrations?status=connected"
OAUTH_ERROR_REDIRECT_URL="http://localhost:3000/settings/integrations?status=error"

# Google OAuth
# Used by /auth/google/start and /auth/google/callback.
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_SCOPES="openid email profile https://www.googleapis.com/auth/youtube.upload"

# X / Twitter OAuth
# Used by /auth/twitter/start and /auth/twitter/callback.
TWITTER_CLIENT_ID="your-x-oauth-client-id"
TWITTER_CLIENT_SECRET="your-x-oauth-client-secret"
TWITTER_SCOPES="tweet.read tweet.write users.read offline.access media.write"

# Meta / Facebook / Instagram publishing
# Used by the scheduler publisher for Facebook Page and Instagram Business publishing.
META_ACCESS_TOKEN="your-meta-page-or-system-user-access-token"
META_PAGE_ID="your-facebook-page-id"
META_INSTAGRAM_USER_ID="your-instagram-business-user-id"

# Scheduler
SCHEDULER_POLL_SECONDS="30"
