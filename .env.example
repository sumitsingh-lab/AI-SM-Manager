DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ai_sm_manager?schema=public"
API_BASE_URL="http://localhost:8000"
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"
GCS_BUCKET_NAME="your-gcs-bucket-name"
GCS_PROJECT_ID="your-gcp-project-id"
GCS_SIGNED_URL_MINUTES="60"
GCS_MAKE_PUBLIC="false"
MAX_UPLOAD_BYTES="104857600"
MAX_REQUEST_BODY_BYTES="157286400"
TOKEN_ENCRYPTION_KEY="generate-with-python-m-cryptography-fernet"
OAUTH_REDIRECT_BASE_URL="http://localhost:8000"
OAUTH_SUCCESS_REDIRECT_URL="http://localhost:3000/settings/integrations?status=connected"
OAUTH_ERROR_REDIRECT_URL="http://localhost:3000/settings/integrations?status=error"
GOOGLE_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_SCOPES="openid email profile https://www.googleapis.com/auth/youtube.upload"
TWITTER_CLIENT_ID="your-x-oauth-client-id"
TWITTER_CLIENT_SECRET="your-x-oauth-client-secret"
TWITTER_SCOPES="tweet.read tweet.write users.read offline.access media.write"
OPENAI_API_KEY="your-openai-api-key"
AI_COPYWRITER_MODEL="gpt-4.1-mini"
AI_REVIEWER_MODEL="gpt-4.1-mini"
IMAGE_OUTPUT_FORMAT="PNG"
SCHEDULER_POLL_SECONDS="30"
META_ACCESS_TOKEN="your-meta-page-access-token"
META_PAGE_ID="your-facebook-page-id"
META_INSTAGRAM_USER_ID="your-instagram-business-user-id"
